{{- /* Interactive zsh init. */ -}}
# ~/.zshrc — managed by chezmoi. Edit the source: home/dot_zshrc.tmpl

# History.
HISTFILE="$XDG_STATE_HOME/zsh/history"
[[ -d $HISTFILE:h ]] || mkdir -p "$HISTFILE:h"
HISTSIZE=50000
SAVEHIST=50000
setopt EXTENDED_HISTORY HIST_IGNORE_DUPS HIST_IGNORE_SPACE HIST_REDUCE_BLANKS
setopt SHARE_HISTORY INC_APPEND_HISTORY

# Sane defaults.
setopt AUTO_CD AUTO_PUSHD PUSHD_IGNORE_DUPS NO_BEEP CORRECT INTERACTIVE_COMMENTS

# Completion.
autoload -Uz compinit
ZSH_COMPDUMP="$XDG_CACHE_HOME/zsh/zcompdump"
[[ -d $ZSH_COMPDUMP:h ]] || mkdir -p "$ZSH_COMPDUMP:h"
compinit -d "$ZSH_COMPDUMP"

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}' 'r:|=*' 'l:|=* r:|=*'
zstyle ':completion:*:descriptions' format '%F{cyan}-- %d --%f'
zstyle ':completion:*' group-name ''

# Source modular config (aliases / functions / keybindings).
for f in "$XDG_CONFIG_HOME"/zsh/*.zsh(N); do
  source "$f"
done

# starship prompt.
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi

# zoxide (smarter cd).
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

# atuin (history search).
if command -v atuin >/dev/null 2>&1; then
  eval "$(atuin init zsh --disable-up-arrow)"
fi

# fzf keybindings + completion.
{{ if eq .chezmoi.os "darwin" -}}
if [[ -r "$(brew --prefix 2>/dev/null)/opt/fzf/shell/key-bindings.zsh" ]]; then
  source "$(brew --prefix)/opt/fzf/shell/key-bindings.zsh"
  source "$(brew --prefix)/opt/fzf/shell/completion.zsh"
fi
{{- else -}}
[[ -r /usr/share/doc/fzf/examples/key-bindings.zsh ]] && source /usr/share/doc/fzf/examples/key-bindings.zsh
[[ -r /usr/share/doc/fzf/examples/completion.zsh ]]   && source /usr/share/doc/fzf/examples/completion.zsh
{{- end }}

# mise activation (per-project tool versions).
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi

# Greet on launch (only first interactive shell, not nested).
if [[ -z "${OMNIDECK_GREETED-}" && -o interactive ]]; then
  export OMNIDECK_GREETED=1
  command -v fastfetch >/dev/null 2>&1 && fastfetch
fi
