{{- /* SSH client config. Keys are NOT in this repo; place them at ~/.ssh/ manually. */ -}}
# ~/.ssh/config — managed by chezmoi.

###############################################################################
# Defaults applied to every host                                              #
###############################################################################

Host *
    AddKeysToAgent     yes
    ServerAliveInterval 60
    ServerAliveCountMax 3
    HashKnownHosts     yes
    VerifyHostKeyDNS   ask
    UpdateHostKeys     ask
    Compression        yes
    ControlMaster      auto
    ControlPath        ~/.ssh/.ctrl-%C
    ControlPersist     10m
{{ if eq .chezmoi.os "darwin" -}}
    UseKeychain        yes
    IdentityFile       ~/.ssh/id_ed25519
{{- else -}}
    IdentityFile       ~/.ssh/id_ed25519
{{- end }}

###############################################################################
# Forges                                                                      #
###############################################################################

Host github.com
    HostName ssh.github.com
    Port     443
    User     git
    IdentitiesOnly yes
    IdentityFile ~/.ssh/id_ed25519

Host gitlab.com
    HostName gitlab.com
    User     git
    IdentitiesOnly yes
    IdentityFile ~/.ssh/id_ed25519

###############################################################################
# Personal homelab (override per machine via ~/.ssh/config.local)             #
###############################################################################

Include ~/.ssh/config.local
