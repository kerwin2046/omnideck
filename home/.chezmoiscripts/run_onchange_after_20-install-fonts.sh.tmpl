{{- /* Install JetBrainsMono Nerd Font.
       macOS: comes through brew --cask font-jetbrains-mono-nerd-font, so this
              script just verifies and runs `fc-cache` if available.
       Linux: download the latest release from the Nerd Fonts repo and unpack
              into ~/.local/share/fonts.
*/ -}}
#!/usr/bin/env bash
set -euo pipefail

log()  { printf '\033[1;36m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m  %s\n' "$*" >&2; }

FONT_FAMILY="{{ .theme.font.family }}"
FONT_NAME="JetBrainsMono"

font_installed() {
  if command -v fc-list >/dev/null 2>&1; then
    fc-list | grep -qi "$FONT_NAME"
  else
    [[ -n "$(ls -A "$HOME/Library/Fonts" 2>/dev/null | grep -i "$FONT_NAME" || true)" ]]
  fi
}

if font_installed; then
  log "$FONT_FAMILY already installed"
  exit 0
fi

{{ if eq .chezmoi.os "linux" -}}
log "Installing $FONT_FAMILY from Nerd Fonts release"
mkdir -p "$HOME/.local/share/fonts/$FONT_NAME"
tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT

asset_url=$(curl -fsSL https://api.github.com/repos/ryanoasis/nerd-fonts/releases/latest \
  | grep -E '"browser_download_url"' \
  | grep -E "/${FONT_NAME}\\.zip\"" \
  | head -n1 \
  | cut -d '"' -f 4)

if [ -z "$asset_url" ]; then
  warn "could not locate ${FONT_NAME}.zip in latest Nerd Fonts release"
  exit 1
fi

curl -fsSL "$asset_url" -o "$tmp/font.zip"
unzip -qo "$tmp/font.zip" -d "$HOME/.local/share/fonts/$FONT_NAME"
fc-cache -f "$HOME/.local/share/fonts/$FONT_NAME"
{{- end }}

{{ if eq .chezmoi.os "darwin" -}}
log "Refreshing macOS font cache"
atsutil databases -remove >/dev/null 2>&1 || true
{{- end }}

log "$FONT_FAMILY installed"
