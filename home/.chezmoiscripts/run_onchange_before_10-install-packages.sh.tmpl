{{- /*
   Install all packages declared in home/.chezmoidata/packages.yaml.

   Variables are computed up-front; the body below is plain shell with a
   handful of `{{ ... }}` interpolations. This keeps whitespace simple.
*/ -}}
{{- $cats := list "core" "cli_modern" "shell" "git" "runtime" -}}
{{- if .install_docker }}{{ $cats = append $cats "container" }}{{ end -}}
{{- if .install_gui -}}
  {{- if eq .chezmoi.os "darwin" }}{{ $cats = append $cats "gui_mac" }}
  {{- else if eq .chezmoi.os "linux" }}{{ $cats = append $cats "gui_linux" }}
  {{- end -}}
{{- end -}}
{{- $cats = append $cats "fonts" -}}

{{- /* Aggregate package lists across the active categories. */ -}}
{{- $brew := list -}}
{{- $cask := list -}}
{{- $apt := list -}}
{{- $cargo := list -}}
{{- $releases := list -}}
{{- range $cat := $cats -}}
  {{- with index $.packages $cat -}}
    {{- range $p := .brew           }}{{ $brew     = append $brew     $p }}{{ end -}}
    {{- range $p := .brew_cask      }}{{ $cask     = append $cask     $p }}{{ end -}}
    {{- range $p := .apt            }}{{ $apt      = append $apt      $p }}{{ end -}}
    {{- range $p := .cargo_fallback }}{{ $cargo    = append $cargo    $p }}{{ end -}}
    {{- range $r := .github_release }}{{ $releases = append $releases $r }}{{ end -}}
  {{- end -}}
{{- end -}}
{{- $brew  = $brew  | uniq -}}
{{- $cask  = $cask  | uniq -}}
{{- $apt   = $apt   | uniq -}}
{{- $cargo = $cargo | uniq -}}
#!/usr/bin/env bash
# Generated by chezmoi from run_onchange_before_10-install-packages.sh.tmpl.
# Do not edit the rendered copy — edit the template + .chezmoidata/packages.yaml.

set -euo pipefail

log()  { printf '\033[1;36m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m  %s\n' "$*" >&2; }

{{ if eq .chezmoi.os "darwin" -}}
###############################################################################
# macOS: brew + brew --cask                                                   #
###############################################################################

command -v brew >/dev/null 2>&1 || { echo "brew missing"; exit 1; }

log "brew install (formulae)"
brew install --quiet {{ $brew | join " " }}

{{ if $cask -}}
log "brew install --cask"
brew install --cask --quiet {{ $cask | join " " }} \
  || warn "some casks failed (likely already installed via App Store)"
{{ end -}}
{{ end -}}

{{ if eq .chezmoi.os "linux" -}}
###############################################################################
# Debian: apt + cargo fallback + GitHub release fallback                      #
###############################################################################

command -v apt-get >/dev/null 2>&1 || { echo "apt-get missing"; exit 1; }

log "apt install"
sudo DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
  {{ $apt | join " " }}

# bat ships as `batcat` on Debian; symlink it to `bat` for parity with macOS.
if command -v batcat >/dev/null 2>&1 && ! command -v bat >/dev/null 2>&1; then
  mkdir -p "$HOME/.local/bin"
  ln -sf "$(command -v batcat)" "$HOME/.local/bin/bat"
fi
# Same idea for fd-find.
if command -v fdfind >/dev/null 2>&1 && ! command -v fd >/dev/null 2>&1; then
  mkdir -p "$HOME/.local/bin"
  ln -sf "$(command -v fdfind)" "$HOME/.local/bin/fd"
fi

{{ if $cargo -}}
if ! command -v cargo >/dev/null 2>&1; then
  log "Installing rustup (needed for cargo fallback)"
  curl --proto '=https' --tlsv1.2 -fsSL https://sh.rustup.rs \
    | sh -s -- -y --default-toolchain stable --no-modify-path
  # shellcheck disable=SC1091
  . "$HOME/.cargo/env"
fi
for crate in {{ $cargo | join " " }}; do
  case "$crate" in
    du-dust)   bin_name="dust"  ;;
    git-delta) bin_name="delta" ;;
    tealdeer)  bin_name="tldr"  ;;
    *)         bin_name="$crate" ;;
  esac
  if ! command -v "$bin_name" >/dev/null 2>&1; then
    log "cargo install $crate"
    cargo install --locked "$crate"
  fi
done
{{ end -}}

{{ range $r := $releases }}
if ! command -v {{ $r.bin }} >/dev/null 2>&1; then
  log "Installing {{ $r.bin }} from github.com/{{ $r.repo }}"
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT
  asset_url=$(curl -fsSL "https://api.github.com/repos/{{ $r.repo }}/releases/latest" \
    | grep -E '"browser_download_url"' \
    | grep -E "{{ $r.asset_pattern }}" \
    | head -n1 \
    | cut -d '"' -f 4)
  if [ -z "$asset_url" ]; then
    warn "no asset matched pattern {{ $r.asset_pattern }} for {{ $r.repo }}"
  else
    curl -fsSL "$asset_url" -o "$tmp/asset.tar.gz"
    tar -xzf "$tmp/asset.tar.gz" -C "$tmp"
    install -Dm 0755 "$(find "$tmp" -type f -name {{ $r.bin }} | head -n1)" "$HOME/.local/bin/{{ $r.bin }}"
  fi
  trap - EXIT
  rm -rf "$tmp"
fi
{{ end -}}

{{ if .install_docker }}
if ! command -v docker >/dev/null 2>&1; then
  log "Installing docker-ce"
  sudo DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
  sudo usermod -aG docker "$USER" || true
fi
{{ end -}}
{{ end }}
log "Package install complete"
