{{- /* Make zsh the user's login shell. Runs only once per machine. */ -}}
#!/usr/bin/env bash
set -euo pipefail

log()  { printf '\033[1;36m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m  %s\n' "$*" >&2; }

zsh_path="$(command -v zsh || true)"
if [ -z "$zsh_path" ]; then
  warn "zsh not found on PATH; skipping default-shell switch"
  exit 0
fi

current_shell="$(getent passwd "$USER" 2>/dev/null | cut -d: -f7 || dscl . -read "/Users/$USER" UserShell 2>/dev/null | awk '{print $2}' || echo "$SHELL")"
if [ "$current_shell" = "$zsh_path" ]; then
  log "zsh is already the default shell"
  exit 0
fi

# Make sure $zsh_path is registered in /etc/shells (Linux + macOS both honour this).
if [ -w /etc/shells ] || sudo -n true 2>/dev/null; then
  if ! grep -qx "$zsh_path" /etc/shells; then
    log "Registering $zsh_path in /etc/shells"
    echo "$zsh_path" | sudo tee -a /etc/shells >/dev/null
  fi
else
  warn "cannot edit /etc/shells without sudo; chsh may fail"
fi

log "Switching default shell to $zsh_path"
if ! chsh -s "$zsh_path" "$USER"; then
  warn "chsh failed; you may need to run \`chsh -s $zsh_path\` manually"
fi
